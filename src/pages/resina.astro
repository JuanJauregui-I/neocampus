---
import '../styles/global.css';

// Variables para personalizar rápido tu curso
const nombreCurso = "Máster en Pestañas Pelo a Pelo";
const precioNormal = "$100";
const precioDescuento = "$49.99";
const linkHotmart = "https://go.hotmart.com/F106210282M?ap=8b35"; // <-- Cambia esto por tu HotLink

// src/pages/resina.astro
const title = "Diseña y Crea con Resina | NeoCampus";
const description = "Descubre cómo crear accesorios únicos en resina desde cero. Acceso de por vida, soporte continuo y certificado incluido.";
